# EcoFlow Cloud Auto-Configuration
# Copy this file to .env and fill in your credentials
#
# Two auth modes are supported. Use ONE of the sections below.

# ── Option A: Private API (email + password) ──────────────────────────────────
# Use your EcoFlow account credentials (same as the mobile app).
# ECOFLOW_USERNAME=your_email@example.com
# ECOFLOW_PASSWORD=your_password
# Private API host (default is api.ecoflow.com — no need to set this usually)
# ECOFLOW_API_HOST=api.ecoflow.com

# ── Option B: Public API (access key + secret key) ───────────────────────────
# Get these from the EcoFlow Developer Portal: https://developer.ecoflow.com/
# ECOFLOW_ACCESS_KEY=your_access_key_here
# ECOFLOW_SECRET_KEY=your_secret_key_here
# Public API host (default: api-e.ecoflow.com for Europe)
# Use api-a.ecoflow.com for Americas/Asia
# ECOFLOW_API_HOST=api-e.ecoflow.com

# ── Required: Devices to configure ───────────────────────────────────────────
# JSON array. Each device needs: sn (serial number), name, type.
# Find your SN in the EcoFlow app under device settings.
# IMPORTANT: Wrap JSON in single quotes to prevent shell interpretation!
#
# Private API device types: STREAM_AC, STREAM_PRO, STREAM_ULTRA,
#   DELTA_PRO, DELTA_2, RIVER_2, RIVER_2_PRO, etc.
# Public API device types:  Stream AC, Stream PRO, Stream Ultra,
#   Smart Home Panel, DELTA 2, DELTA PRO, etc.
#
# Example (private API, Stream AC):
# ECOFLOW_DEVICES='[{"sn": "BK1234567890", "name": "Stream AC", "type": "STREAM_AC"}]'
#
# Example (public API, Smart Home Panel):
# ECOFLOW_DEVICES='[{"sn": "YOUR_DEVICE_SN", "name": "Smart Home Panel", "type": "Smart Home Panel"}]'

ECOFLOW_DEVICES='[{"sn": "YOUR_DEVICE_SN", "name": "My Device", "type": "STREAM_AC"}]'

# ── Optional ──────────────────────────────────────────────────────────────────
# ECOFLOW_GROUP=Home
